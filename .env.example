# Copy this file to .env and fill in your key. The app loads .env automatically.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-6

# Set to 1 to surface WHY the narrator fell back (adds _fallback_reason to the
# response and prints the error). Leave unset in normal use.
# NARRATOR_DEBUG=1

# --- if using OpenAI instead ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
